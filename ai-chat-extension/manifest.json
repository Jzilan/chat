{
  "manifest_version": 3,
  "name": "AI Chat Assistant",
  "version": "2.0.0",
  "description": "悬浮球 AI 对话助手 - 支持多人物人设和自定义 API 配置",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js", "content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
